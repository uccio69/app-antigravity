# ===========================================
# Variabili d'ambiente - app-antigravity
# ===========================================
# Copia questo file come .env e compila i valori.
# NON committare il file .env con i valori reali.

# --- API Keys ---
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...

# --- Database ---
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# --- Google OAuth ---
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...

# --- App Config ---
# APP_ENV=development
# DEBUG=true
